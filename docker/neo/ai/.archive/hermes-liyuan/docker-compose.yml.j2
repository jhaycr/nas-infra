---

services:

  hermes-liyuan:
    image: nousresearch/hermes-agent:latest
    container_name: hermes-liyuan
    command: gateway run
    init: true
    mem_limit: 2g
    cpus: "1.5"
    shm_size: "1g"
    pids_limit: 512
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    env_file:
      - .env
    environment:
      HERMES_DASHBOARD: "1"
    volumes:
      - {{ docker_appdata_path }}/hermes/profiles/liyuan:/opt/data
    ports:
      - "127.0.0.1:8643:8642"
      - "127.0.0.1:9120:9119"
    networks:
      - default
