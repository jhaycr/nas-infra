---
services:

  # Forge has no server mode — this runs a full desktop (LinuxServer Webtop,
  # KasmVNC-in-browser) with Forge installed as a regular XFCE app. One
  # "player" hosts a game from inside the desktop; other players connect
  # from their own Forge clients over TCP 36743 (see PLAYING.md in the
  # Forge release docs — Forge multiplayer is peer-to-peer, not a server
  # container).
  #
  # forge-init: the compose-generation pipeline (jhaycr-local.docker_compose)
  # hardcodes mode 0644 when it templates appdata files, but LinuxServer's
  # custom-cont-init.d silently ignores any script that isn't executable.
  # This one-shot helper fixes the bit on the shared volume before webtop's
  # init runs, then exits; forge waits for it via depends_on/service_completed_successfully.
  #
  # Both services carry the "manual" profile so `make neo-docker` (plain
  # `up --remove-orphans`, no --profile flag) never starts either one, and a
  # running instance is left alone by later deploys. forge-init shares the
  # profile so that explicitly targeting `forge` (which auto-activates a
  # targeted service's own profile) also brings up its first-level
  # depends_on dependency without needing a separate --profile flag.
  forge-init:
    container_name: forge-init
    image: busybox:1.38.0
    profiles:
      - manual
    command: ["sh", "-c", "chmod +x /custom-cont-init.d/*.sh"]
    volumes:
      - {{ docker_appdata_path }}/forge/custom-cont-init.d:/custom-cont-init.d

  forge:
    container_name: forge
    image: lscr.io/linuxserver/webtop:ubuntu-xfce-version-4c34ccd4
    shm_size: "1gb"
    profiles:
      - manual
    depends_on:
      forge-init:
        condition: service_completed_successfully
    environment:
      DOCKER_MODS: linuxserver/mods:universal-package-install
      # bzip2 is required at runtime: forge-installer-*.tar.bz2 needs it to
      # decompress (tar -xjf shells out to bzip2), but the webtop base image
      # doesn't ship it — confirmed missing via `docker exec forge which
      # bzip2` after a real install failure (tar exited 2, empty version dir
      # left behind). openjdk-17-jre is Forge's own runtime requirement.
      INSTALL_PACKAGES: openjdk-17-jre|bzip2
    volumes:
      - {{ docker_appdata_path }}/forge:/config
      - {{ docker_appdata_path }}/forge/custom-cont-init.d:/custom-cont-init.d:ro
    ports:
      - "3010:3000"
      - "36743:36743"
