#!/bin/bash
# Installs Forge (github.com/Card-Forge/forge) into /config on first boot.
# Runs as root via LinuxServer's custom-cont-init.d, after PUID/PGID mapping
# and DOCKER_MODS (so `java` is already on PATH by the time this runs).
#
# Idempotent: skips the download/unpack if this pinned version is already
# present. To reinstall a version, delete its dir under /config/forge/ and
# re-run (`docker restart forge` re-runs custom-cont-init.d).
#
# Version pin lives in group_vars/neo/vars.yml (forge_version) — bump it
# there to point at a newer github.com/Card-Forge/forge release tag, then
# redeploy. Check https://github.com/Card-Forge/forge/releases for the
# current forge-installer-<version>.tar.bz2 asset before bumping.

set -euo pipefail

FORGE_VERSION="{{ forge_version }}"
FORGE_HOME="/config/forge"
FORGE_DIR="${FORGE_HOME}/forge-${FORGE_VERSION}"
FORGE_ASSET="forge-installer-${FORGE_VERSION}.tar.bz2"
FORGE_URL="https://github.com/Card-Forge/forge/releases/download/forge-${FORGE_VERSION}/${FORGE_ASSET}"
DESKTOP_DIR="/config/Desktop"

if [[ -x "${FORGE_DIR}/forge.sh" ]]; then
    echo "[forge-init] Forge ${FORGE_VERSION} already installed at ${FORGE_DIR}, skipping."
else
    echo "[forge-init] Installing Forge ${FORGE_VERSION} to ${FORGE_DIR}..."
    mkdir -p "${FORGE_HOME}"

    # Clear out any stage dir left behind by a previous failed attempt
    # (e.g. the container killed mid-install) before starting a new one.
    rm -rf "${FORGE_HOME}"/.stage-*

    # Extract into a staging dir on the same volume as FORGE_DIR (not /tmp,
    # which is a different filesystem), then mv into place as the final
    # step. That mv is a same-filesystem rename, so FORGE_DIR itself never
    # exists in a half-extracted state: either the real thing or nothing.
    # A failed run (e.g. tar exiting non-zero, as happened when this image
    # was missing bzip2) leaves only a stray .stage-* dir, which the guard
    # above ignores — it only checks FORGE_DIR/forge.sh — so a rerun still
    # retries cleanly.
    STAGE_DIR="$(mktemp -d "${FORGE_HOME}/.stage-${FORGE_VERSION}-XXXXXX")"
    trap 'rm -rf "${STAGE_DIR}"' EXIT
    TMP_TARBALL="${STAGE_DIR}/download.tar.bz2"
    curl -fsSL -o "${TMP_TARBALL}" "${FORGE_URL}"
    # The release tarball is flat (no wrapping top-level dir) — unpack
    # straight into the staging dir.
    tar -xjf "${TMP_TARBALL}" -C "${STAGE_DIR}"
    rm -f "${TMP_TARBALL}"
    chmod +x "${STAGE_DIR}"/*.sh
    mv "${STAGE_DIR}" "${FORGE_DIR}"
    trap - EXIT
    echo "[forge-init] Forge ${FORGE_VERSION} installed."
fi

# Stable path for the launcher regardless of which version is pinned.
ln -sfn "${FORGE_DIR}" "${FORGE_HOME}/current"

mkdir -p "${DESKTOP_DIR}"
cat > "${DESKTOP_DIR}/forge.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Forge (MTG)
Comment=Forge ${FORGE_VERSION} - MTG rules engine, github.com/Card-Forge/forge
Exec=${FORGE_HOME}/current/forge.sh
Path=${FORGE_HOME}/current
Icon=applications-games
Terminal=false
Categories=Game;
EOF
chmod +x "${DESKTOP_DIR}/forge.desktop"

chown -R abc:abc "${FORGE_HOME}" "${DESKTOP_DIR}"

echo "[forge-init] Ready. Launch from the XFCE desktop shortcut, or: ${FORGE_HOME}/current/forge.sh"
