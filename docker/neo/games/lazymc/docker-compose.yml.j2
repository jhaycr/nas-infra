---
# lazymc-docker-proxy: sidecar TCP proxies that hibernate Minecraft server containers.
# Each proxy listens on port 25565 and manages one server via Docker labels.
# Velocity must point to lazymc-survival/lazymc-pvp instead of the real servers.
# Docs: https://github.com/joesturge/lazymc-docker-proxy

services:

  lazymc-survival:
    image: ghcr.io/joesturge/lazymc-docker-proxy:latest
    container_name: lazymc-survival
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - minecraft
    restart: unless-stopped

  lazymc-pvp:
    image: ghcr.io/joesturge/lazymc-docker-proxy:latest
    container_name: lazymc-pvp
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - minecraft
    restart: unless-stopped
