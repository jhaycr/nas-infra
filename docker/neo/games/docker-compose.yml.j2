name: games

include:
  - path: minecraft/docker-compose.yml
  - path: minecraft-proxy/docker-compose.yml
  - path: forge/docker-compose.yml
  - path: xmage/docker-compose.yml
  # - path: stardew/docker-compose.yml
  #  env_file: stardew/.env
  # - path: terraria/docker-compose.yml
  
networks:
  minecraft:
    driver: bridge
  # lazymc needs static backend IPs: docker DNS names vanish while a managed
  # container is stopped, so its server.address labels use fixed addresses.
  minecraft-lazy:
    driver: bridge
    ipam:
      config:
        - subnet: 10.86.86.0/24
