---

services:

  # https://hangar.papermc.io/ViaVersion/ViaVersion
  # https://hangar.papermc.io/ViaVersion/ViaBackwards
  # https://hangar.papermc.io/ViaVersion/ViaRewind

  minecraft-lobby:
    container_name: minecraft-lobby
    image: itzg/minecraft-server:2026.7.0
    dns:
      - 1.1.1.1
      - 8.8.8.8
    environment:
      EULA: "true"
      TYPE: "PAPER"
      VERSION: "{{ minecraft_versions.paper }}"
      ONLINE_MODE: "false"
      VELOCITY_ENABLED: "true"
      VELOCITY_SECRET: {{ secret_minecraft_velocity_secret }}
      SERVER_NAME: Lobby
      MODE: "creative"
      DIFFICULTY: "peaceful"
      MAX_PLAYERS: "12"
      MEMORY: "768M"
      USE_AIKAR_FLAGS: "true"
      VIEW_DISTANCE: "4"
      SIMULATION_DISTANCE: "4"
      SEED: "4859979374641661651"
      # Last PLUGINS entry: ServerSelector 1.8-1 (compass server picker GUI)
      # https://modrinth.com/plugin/serverselector
      PLUGINS: |
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaVersion/versions/{{ minecraft_versions.viaversion }}/PAPER/ViaVersion-{{ minecraft_versions.viaversion }}.jar
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaBackwards/versions/{{ minecraft_versions.viabackwards }}/PAPER/ViaBackwards-{{ minecraft_versions.viabackwards }}.jar
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaRewind/versions/{{ minecraft_versions.viarewind }}/PAPER/ViaRewind-{{ minecraft_versions.viarewind }}.jar
        https://cdn.modrinth.com/data/eCvG237D/versions/{{ minecraft_versions.serverselector_modrinth_file }}/ServerSelector-{{ minecraft_versions.serverselector_version }}.jar
    networks:
      - minecraft
    volumes:
      - {{ docker_appdata_path }}/minecraft-lobby:/data
    restart: unless-stopped

  minecraft-survival:
    container_name: minecraft-survival
    image: itzg/minecraft-server:2026.7.0
    dns:
      - 1.1.1.1
      - 8.8.8.8
    environment:
      EULA: "true"
      TYPE: "PAPER"
      VERSION: "{{ minecraft_versions.paper }}"
      ONLINE_MODE: "false"
      VELOCITY_ENABLED: "true"
      VELOCITY_SECRET: {{ secret_minecraft_velocity_secret }}
      SERVER_NAME: Survival
      MODE: "survival"
      DIFFICULTY: "normal"
      MAX_PLAYERS: "16"
      PLUGINS: |
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaVersion/versions/{{ minecraft_versions.viaversion }}/PAPER/ViaVersion-{{ minecraft_versions.viaversion }}.jar
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaBackwards/versions/{{ minecraft_versions.viabackwards }}/PAPER/ViaBackwards-{{ minecraft_versions.viabackwards }}.jar
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaRewind/versions/{{ minecraft_versions.viarewind }}/PAPER/ViaRewind-{{ minecraft_versions.viarewind }}.jar
    labels:
      lazymc.enabled: "true"
      lazymc.group: "survival"
      lazymc.server.address: "10.86.86.11:25565"
      lazymc.port: "25566"
      lazymc.join.kick.starting: "Survival is waking up! Try again in about a minute."
      lazymc.server.directory: "/server/survival"
      lazymc.public.version: "{{ minecraft_versions.paper }}"
      lazymc.public.protocol: "{{ minecraft_versions.paper_protocol }}"
      lazymc.time.sleep_after: "1800"
      lazymc.server.start_timeout: "300"
      lazymc.server.stop_timeout: "120"
    networks:
      minecraft: {}
      minecraft-lazy:
        ipv4_address: 10.86.86.11
    volumes:
      - {{ docker_appdata_path }}/minecraft-1:/data
    restart: "no"

  minecraft-pvp:
    container_name: minecraft-pvp
    image: itzg/minecraft-server:2026.7.0
    dns:
      - 1.1.1.1
      - 8.8.8.8
    environment:
      EULA: "true"
      TYPE: "PAPER"
      VERSION: "{{ minecraft_versions.paper }}"
      ONLINE_MODE: "false"
      VELOCITY_ENABLED: "true"
      VELOCITY_SECRET: {{ secret_minecraft_velocity_secret }}
      SERVER_NAME: PVP
      # Dedicated flat arena world (old "world" dir stays on the volume;
      # revert = drop LEVEL/LEVEL_TYPE). Adventure mode keeps the arena
      # ungriefable while PVP still works; bin/minecraft-build-pvp-arena.sh
      # builds the arena and sets gamerules.
      LEVEL: "arena"
      LEVEL_TYPE: "FLAT"
      GENERATE_STRUCTURES: "false"
      MODE: "adventure"
      FORCE_GAMEMODE: "true"
      DIFFICULTY: "normal"
      MAX_PLAYERS: "16"
      PVP: "true"
      ENABLE_COMMAND_BLOCK: "false"
      SPAWN_PROTECTION: "0"
      VIEW_DISTANCE: "10"
      SIMULATION_DISTANCE: "8"
      PLUGINS: |
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaVersion/versions/{{ minecraft_versions.viaversion }}/PAPER/ViaVersion-{{ minecraft_versions.viaversion }}.jar
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaBackwards/versions/{{ minecraft_versions.viabackwards }}/PAPER/ViaBackwards-{{ minecraft_versions.viabackwards }}.jar
        https://hangarcdn.papermc.io/plugins/ViaVersion/ViaRewind/versions/{{ minecraft_versions.viarewind }}/PAPER/ViaRewind-{{ minecraft_versions.viarewind }}.jar
        https://download.luckperms.net/{{ minecraft_versions.luckperms_build }}/bukkit/loader/LuckPerms-Bukkit-{{ minecraft_versions.luckperms_version }}.jar
      # PlayerKits 2 (kits via /kit GUI): https://www.spigotmc.org/resources/112616/
      SPIGET_RESOURCES: "{{ minecraft_versions.playerkits_spiget_id }}"
    labels:
      lazymc.enabled: "true"
      lazymc.group: "pvp"
      lazymc.server.address: "10.86.86.12:25565"
      lazymc.port: "25567"
      lazymc.join.kick.starting: "The PVP Arena is waking up! Try again in about a minute."
      lazymc.server.directory: "/server/pvp"
      lazymc.public.version: "{{ minecraft_versions.paper }}"
      lazymc.public.protocol: "{{ minecraft_versions.paper_protocol }}"
      lazymc.time.sleep_after: "1800"
      lazymc.server.start_timeout: "300"
      lazymc.server.stop_timeout: "120"
    networks:
      minecraft: {}
      minecraft-lazy:
        ipv4_address: 10.86.86.12
    volumes:
      - {{ docker_appdata_path }}/minecraft-2:/data
    restart: "no"

  # Sleeps survival/pvp when empty and wakes them on join. Velocity points at
  # this container (ports 25566/25567) instead of the backends directly.
  lazymc:
    container_name: lazymc
    image: ghcr.io/joesturge/lazymc-docker-proxy:v2.7.5
    networks:
      minecraft: {}
      minecraft-lazy:
        ipv4_address: 10.86.86.10
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ docker_appdata_path }}/minecraft-1:/server/survival:ro
      - {{ docker_appdata_path }}/minecraft-2:/server/pvp:ro
    restart: unless-stopped

  # Pre-warms survival: polls the lobby's status ping and fires a throwaway
  # login at lazymc as soon as anyone is in the lobby, so the /server switch
  # doesn't hit a cold start.
  minecraft-warmer:
    container_name: minecraft-warmer
    image: python:3.14-alpine
    command: ["python", "-u", "/app/warmer.py"]
    environment:
      LOBBY_ADDR: "minecraft-lobby:25565"
      TARGETS: "survival=lazymc:25566=10.86.86.11:25565,pvp=lazymc:25567=10.86.86.12:25565"
      PROTOCOL: "{{ minecraft_versions.paper_protocol }}"
    networks:
      minecraft: {}
      minecraft-lazy:
        ipv4_address: 10.86.86.13
    volumes:
      - {{ docker_appdata_path }}/minecraft-warmer:/app:ro
    restart: unless-stopped
