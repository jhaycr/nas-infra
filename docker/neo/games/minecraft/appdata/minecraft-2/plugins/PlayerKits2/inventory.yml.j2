# PlayerKits2 GUI layout for the pvp server: single menu with the four PVP
# kits. Every kit yml in kits/ needs a slot here — the plugin does not
# auto-place file-authored kits, and slots referencing missing kits render
# as error items (this happened when the sample kits were deleted).
inventories:
  main_inventory:
    slots: 36
    title: "&4&lPVP Kits"
    0;1;2;3;4;5;6;7;8;27;28;29;30;31;32;33;34;35:
      item:
        id: "RED_STAINED_GLASS_PANE"
        name: " "
    9;11;13;15;17;18;20;22;24;26:
      item:
        id: "GRAY_STAINED_GLASS_PANE"
        name: " "
    10:
      type: "kit: warrior"
    12:
      type: "kit: archer"
    14:
      type: "kit: knight"
    16:
      type: "kit: ninja"
    19:
      type: "kit: trickster"
    21:
      type: "kit: brawler"
    23:
      type: "kit: bomber"
    25:
      type: "kit: alchemist"
  preview_inventory:
    slots: 54
    title: "&4&lKit Preview"
    45:
      item:
        id: "ARROW"
        name: "&7Go Back"
      open_inventory: previous
  buy_requirements_inventory:
    slots: 27
    title: "&4&lBuy Kit Requirements"
    13:
      item:
        id: "BOOK"
        name: "&c&lRequirements"
        lore:
          - "%kit_requirements_message%"
    10:
      item:
        id: "RED_STAINED_GLASS_PANE"
        name: "&cGo Back"
      type: buy_no
    16:
      item:
        id: "GREEN_STAINED_GLASS_PANE"
        name: "&aBuy"
      type: buy_yes
