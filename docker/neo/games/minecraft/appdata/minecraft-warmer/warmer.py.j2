#!/usr/bin/env python3
"""Wake the survival backend (via lazymc) whenever the lobby has players.

lazymc only starts a sleeping backend when a join reaches it, so switching
servers from the lobby hits Velocity's 5s connect timeout while the
container cold-starts (~60s). This watcher polls the lobby's status ping
and sends a throwaway login to lazymc as soon as anyone connects to the
lobby, so survival is warm by the time they /server over.
"""
import json
import os
import socket
import struct
import time


def _addr(spec):
    host, port = spec.rsplit(":", 1)
    return host, int(port)


LOBBY = _addr(os.environ.get("LOBBY_ADDR", "minecraft-lobby:25565"))
# name=wake_host:port=backend_host:port, comma-separated
TARGETS = [
    (name, _addr(wake), _addr(backend))
    for name, wake, backend in (
        spec.split("=")
        for spec in os.environ.get(
            "TARGETS",
            "survival=lazymc:25566=10.86.86.11:25565,pvp=lazymc:25567=10.86.86.12:25565",
        ).split(",")
    )
]
POLL_SECONDS = int(os.environ.get("POLL_SECONDS", "10"))
WAKE_COOLDOWN = int(os.environ.get("WAKE_COOLDOWN", "180"))
PROTOCOL = int(os.environ.get("PROTOCOL", "776"))


def log(msg):
    print(msg, flush=True)


def varint(n):
    out = b""
    while True:
        b = n & 0x7F
        n >>= 7
        out += bytes([b | (0x80 if n else 0)])
        if not n:
            return out


def mcstring(s):
    b = s.encode()
    return varint(len(b)) + b


def packet(pid, data):
    body = varint(pid) + data
    return varint(len(body)) + body


def handshake(host, port, next_state):
    return packet(
        0, varint(PROTOCOL) + mcstring(host) + struct.pack(">H", port) + varint(next_state)
    )


def read_varint_sock(sock):
    num = 0
    for i in range(5):
        b = sock.recv(1)
        if not b:
            raise EOFError("connection closed mid-varint")
        num |= (b[0] & 0x7F) << (7 * i)
        if not b[0] & 0x80:
            return num
    raise ValueError("varint too long")


def read_varint_bytes(data, pos):
    num = 0
    for i in range(5):
        b = data[pos]
        pos += 1
        num |= (b & 0x7F) << (7 * i)
        if not b & 0x80:
            return num, pos
    raise ValueError("varint too long")


def read_exact(sock, n):
    buf = b""
    while len(buf) < n:
        chunk = sock.recv(n - len(buf))
        if not chunk:
            raise EOFError("connection closed mid-packet")
        buf += chunk
    return buf


def lobby_players():
    """Return the lobby's online player count via a status ping."""
    with socket.create_connection(LOBBY, timeout=3) as s:
        s.settimeout(3)
        s.sendall(handshake(*LOBBY, next_state=1) + packet(0, b""))
        length = read_varint_sock(s)
        data = read_exact(s, length)
    _pid, pos = read_varint_bytes(data, 0)
    strlen, pos = read_varint_bytes(data, pos)
    status = json.loads(data[pos : pos + strlen])
    return status["players"]["online"]


def backend_up(backend):
    try:
        with socket.create_connection(backend, timeout=2):
            return True
    except OSError:
        return False


def send_wake(wake):
    """A login attempt is what makes lazymc start the backend; it never completes."""
    with socket.create_connection(wake, timeout=5) as s:
        s.sendall(handshake(*wake, next_state=2))
        s.sendall(packet(0, mcstring("LobbyWarmer") + b"\x00" * 16))
        time.sleep(1)


def main():
    log(f"warmer: lobby={LOBBY} targets={[t[0] for t in TARGETS]} poll={POLL_SECONDS}s")
    last_wake = {name: 0.0 for name, _, _ in TARGETS}
    last_players = None
    while True:
        try:
            players = lobby_players()
        except (OSError, EOFError, ValueError, KeyError) as e:
            players = None
            if last_players is not None:
                log(f"warmer: lobby ping failed: {e}")
        if players != last_players:
            log(f"warmer: lobby players = {players}")
            last_players = players
        if players:
            for name, wake, backend in TARGETS:
                if time.time() - last_wake[name] > WAKE_COOLDOWN and not backend_up(backend):
                    log(f"warmer: lobby occupied and {name} asleep -> waking")
                    try:
                        send_wake(wake)
                    except OSError as e:
                        log(f"warmer: wake {name} failed: {e}")
                    last_wake[name] = time.time()
        time.sleep(POLL_SECONDS)


if __name__ == "__main__":
    main()
