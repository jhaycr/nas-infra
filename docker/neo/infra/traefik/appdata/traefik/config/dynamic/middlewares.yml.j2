http:
  middlewares:

    # Applied globally to all routers via the websecure entrypoint (traefik.yml)
    hsts:
      headers:
        stsSeconds: 63072000
        stsPreload: true
        stsIncludeSubdomains: false

    # Authentik forward auth — reference with middlewares: ["auth@file,auth-errors@file"] in traefik_services
    # Requires authentik container to be reachable on bridge_proxy_external
    auth:
      forwardAuth:
        address: "http://authentik:9000/outpost.goauthentik.io/auth/traefik"
        trustForwardHeader: true
        authResponseHeaders:
          - X-authentik-username
          - X-authentik-groups
          - X-authentik-email
          - X-authentik-name
          - X-authentik-uid
          - X-authentik-jwt
          - X-authentik-meta-jwks
          - X-authentik-meta-outpost
          - X-authentik-meta-provider
          - X-authentik-meta-app
          - X-authentik-meta-version

    # Redirects 401/403 responses to the Authentik sign-in page
    auth-errors:
      errors:
        status: ["401-403"]
        service: authentik@docker
        query: "/outpost.goauthentik.io/start?rd={url}"
