{% raw %}{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "12.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "logs",
      "name": "Logs",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Disk usage, MergerFS pool status, and SnapRAID logs for neo",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Percentage of space used on each disk mountpoint. Thresholds: yellow=75%, red=90%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "displayMode": "gradient",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=~\"/mnt/(data[1-5]|parity[13]|cache1|storage)\", job=\"integrations/node_exporter\", instance=~\"$instance\"} / node_filesystem_size_bytes{mountpoint=~\"/mnt/(data[1-5]|parity[13]|cache1|storage)\", job=\"integrations/node_exporter\", instance=~\"$instance\"}) * 100",
          "instant": true,
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "title": "Disk Usage % (per mountpoint)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Shows whether each data disk in the MergerFS pool is mounted and visible to node_exporter. If any disk shows Missing, check mergerfs mount and disk health immediately.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": { "color": "red", "index": 0, "text": "Missing" }
              },
              "type": "special"
            },
            {
              "options": {
                "from": 1,
                "result": { "color": "green", "index": 1, "text": "Connected" },
                "to": 1e+15
              },
              "type": "range"
            }
          ],
          "noValue": "Missing",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data1\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data1",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data2\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data2",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data3\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data3",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data4\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data4",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data5\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data5",
          "refId": "E"
        }
      ],
      "title": "MergerFS Pool Disk Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Free space trend over time for data disks, cache, and the MergerFS union mount.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "min"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_avail_bytes{mountpoint=~\"/mnt/(data[1-5]|cache1|storage)\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "title": "Disk Free Space over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "description": "All SnapRAID runner log output. Use the search bar to filter by keyword (e.g. Completed, error, sync, scrub). Logs are collected from /var/log/snapraid.log on the host.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 20 },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "{job=\"snapraid\", instance=~\"$instance\"}",
          "refId": "A"
        }
      ],
      "title": "SnapRAID Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "description": "Each column is one day. Green = completed successfully, Red = errors detected, Grey = no run. Sync runs daily at 1am; scrub runs periodically based on snapraid-runner config.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 90,
            "lineWidth": 0,
            "spanNulls": false
          },
          "mappings": [
            { "options": { "0": { "color": "gray",  "index": 0, "text": "No Run" } }, "type": "value" },
            { "options": { "from": 1, "result": { "color": "green", "index": 1, "text": "OK" },    "to": 9999 }, "type": "range" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray",  "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "0": { "color": "gray",  "index": 0, "text": "No Run" } }, "type": "value" },
                  { "options": { "from": 1, "result": { "color": "red", "index": 1, "text": "Errors" }, "to": 9999 }, "type": "range" }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "gray", "value": null },
                    { "color": "red",  "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 34 },
      "id": 5,
      "options": {
        "alignValue": "center",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "mergeValues": false,
        "rowHeight": 0.8,
        "showValue": "auto",
        "tooltip": { "maxHeight": 600, "mode": "single", "sort": "none" }
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "count_over_time({job=\"snapraid\", instance=~\"$instance\"} |= \"Running sync\" [$__interval])",
          "instant": false,
          "legendFormat": "Sync/Scrub Completed",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "count_over_time({job=\"snapraid\", instance=~\"$instance\"} |= \"Run failed\" [$__interval])",
          "instant": false,
          "legendFormat": "Errors",
          "refId": "B"
        }
      ],
      "title": "SnapRAID Run History",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "description": "Total SnapRAID ERROR-level log lines in the selected time range. Should be 0.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "No Errors" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 40 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "count_over_time({job=\"snapraid\", instance=~\"$instance\"} |= \"[ERROR ]\" [$__range])",
          "instant": true,
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "title": "SnapRAID Errors",
      "type": "stat"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 41,
  "tags": ["disks", "snapraid", "mergerfs", "storage"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(node_filesystem_size_bytes, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": false,
        "name": "instance",
        "options": [],
        "query": {
          "query": "label_values(node_filesystem_size_bytes, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Disk Health",
  "uid": "neo-disk-health-001",
  "version": 1,
  "weekStart": ""
}{% endraw %}
