{% raw %}{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "12.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "logs",
      "name": "Logs",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Disk usage, MergerFS pool status, and SnapRAID logs for neo",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "doc",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "SnapRAID Logs",
      "type": "link",
      "url": "/d/neo-snapraid-logs-001/snapraid-logs"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Percentage of space used on each disk mountpoint. Thresholds: yellow=75%, red=90%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 1,
      "options": {
        "displayMode": "gradient",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=~\"/mnt/(data[1-5]|parity[13]|cache1|storage)\", job=\"integrations/node_exporter\", instance=~\"$instance\"} / node_filesystem_size_bytes{mountpoint=~\"/mnt/(data[1-5]|parity[13]|cache1|storage)\", job=\"integrations/node_exporter\", instance=~\"$instance\"}) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "mountpoint" }] }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "device": true, "fstype": true, "instance": true, "job": true },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ],
      "title": "Disk Usage % (per mountpoint)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Shows whether each data disk in the MergerFS pool is mounted and visible to node_exporter. If any disk shows Missing, check mergerfs mount and disk health immediately.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": { "color": "red", "index": 0, "text": "Missing" }
              },
              "type": "special"
            },
            {
              "options": {
                "from": 1,
                "result": { "color": "green", "index": 1, "text": "Connected" },
                "to": 1e+15
              },
              "type": "range"
            }
          ],
          "noValue": "Missing",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 4 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data1\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data1",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data2\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data2",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data3\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data3",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data4\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data4",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/mnt/data5\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "instant": true,
          "legendFormat": "/mnt/data5",
          "refId": "E"
        }
      ],
      "title": "MergerFS Pool Disk Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Free space trend over time for data disks, cache, and the MergerFS union mount.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "min"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "node_filesystem_avail_bytes{mountpoint=~\"/mnt/(data[1-5]|cache1|storage)\", job=\"integrations/node_exporter\", instance=~\"$instance\"}",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "title": "Disk Free Space over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Overall SMART health assessment per drive. FAILED means the drive is reporting imminent failure — replace immediately.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red",   "index": 0, "text": "FAILED" },
                "1": { "color": "green", "index": 1, "text": "PASSED" }
              },
              "type": "value"
            }
          ],
          "noValue": "No Data",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smartctl_device_smart_status{instance=~\"$instance\", job=\"smartctl\"}",
          "instant": true,
          "legendFormat": "{{ device }}",
          "refId": "A"
        }
      ],
      "title": "Drive SMART Health Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Current drive temperature. Thresholds: yellow=45°C, red=55°C.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 45 },
              { "color": "red",    "value": 55 }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "id": 8,
      "options": {
        "displayMode": "gradient",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smartctl_device_temperature{instance=~\"$instance\", job=\"smartctl\", temperature_type=\"current\"}",
          "instant": true,
          "legendFormat": "{{ device }}",
          "refId": "A"
        }
      ],
      "title": "Drive Temperatures",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Critical SMART error counters — all should be 0. Any non-zero value means sectors are failing or have failed.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": { "0": { "color": "green", "index": 0, "text": "OK" } },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smartctl_device_attribute{instance=~\"$instance\", job=\"smartctl\", attribute_name=\"Reallocated_Sector_Ct\", attribute_value_type=\"raw\"}",
          "instant": true,
          "legendFormat": "{{ device }} Reallocated",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smartctl_device_attribute{instance=~\"$instance\", job=\"smartctl\", attribute_name=\"Current_Pending_Sector\", attribute_value_type=\"raw\"}",
          "instant": true,
          "legendFormat": "{{ device }} Pending",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "smartctl_device_attribute{instance=~\"$instance\", job=\"smartctl\", attribute_name=\"Offline_Uncorrectable\", attribute_value_type=\"raw\"}",
          "instant": true,
          "legendFormat": "{{ device }} Uncorrectable",
          "refId": "C"
        }
      ],
      "title": "Critical SMART Attributes",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "description": "Each column is one day. Green = snapraid-runner finished successfully, Red = a run failed, Grey = no run at all. Sync runs nightly at 1am via snapraid-runner. Click a bar and follow the 'View SnapRAID logs' link (or drag-select days first) to open the logs dashboard for that period.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 90,
            "lineWidth": 0,
            "spanNulls": false
          },
          "links": [
            {
              "title": "View SnapRAID logs",
              "url": "/d/neo-snapraid-logs-001/snapraid-logs?${__url_time_range}"
            }
          ],
          "mappings": [
            { "options": { "0": { "color": "gray",  "index": 0, "text": "No Run" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "OK" } }, "type": "value" },
            { "options": { "from": 2, "result": { "color": "red", "index": 2, "text": "Failed" }, "to": 9999 }, "type": "range" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "id": 5,
      "options": {
        "alignValue": "center",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "mergeValues": false,
        "rowHeight": 0.8,
        "showValue": "auto",
        "tooltip": { "maxHeight": 600, "mode": "single", "sort": "none" }
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "(sum(count_over_time({job=\"snapraid\", instance=~\"$instance\"} |~ \"Run failed$\" [1d])) or vector(0)) * 2 + (sum(count_over_time({job=\"snapraid\", instance=~\"$instance\"} |= \"Run finished successfully\" [1d])) or vector(0))",
          "instant": false,
          "legendFormat": "SnapRAID Run",
          "step": "1d",
          "refId": "A"
        }
      ],
      "title": "SnapRAID Run History",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "description": "Total SnapRAID ERROR-level log lines in the selected time range. Should be 0.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "No Errors" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "count_over_time({job=\"snapraid\", instance=~\"$instance\"} |= \"[ERROR ]\" [$__range])",
          "instant": true,
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "title": "SnapRAID Errors",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "description": "Outcome of the most recent nightly snapraid-runner run (last 24h). Grey/orange = no run completed in 24h (stuck or cron disabled), green = success, red = failed.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "orange", "index": 0, "text": "No Run (24h)" } }, "type": "value" },
            { "options": { "1": { "color": "green",  "index": 1, "text": "OK" } }, "type": "value" },
            { "options": { "from": 2, "result": { "color": "red", "index": 2, "text": "Failed" }, "to": 9999 }, "type": "range" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 36 },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "(sum(count_over_time({job=\"snapraid\", instance=~\"$instance\"} |~ \"Run failed$\" [1d])) or vector(0)) * 2 + (sum(count_over_time({job=\"snapraid\", instance=~\"$instance\"} |= \"Run finished successfully\" [1d])) or vector(0))",
          "instant": true,
          "legendFormat": "Last Run",
          "refId": "A"
        }
      ],
      "title": "Last Nightly Run",
      "type": "stat"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 41,
  "tags": ["disks", "snapraid", "mergerfs", "storage"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(node_filesystem_size_bytes, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": false,
        "name": "instance",
        "options": [],
        "query": {
          "query": "label_values(node_filesystem_size_bytes, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Disk Health",
  "uid": "neo-disk-health-001",
  "version": 1,
  "weekStart": ""
}{% endraw %}
