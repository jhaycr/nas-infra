OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_OIDC_ISSUER_URL=https://auth.{{ secret_domain }}
OAUTH2_PROXY_CLIENT_ID={{ secret_oauth2_proxy_client_id }}
OAUTH2_PROXY_CLIENT_SECRET={{ secret_oauth2_proxy_client_secret }}
OAUTH2_PROXY_COOKIE_SECRET={{ secret_oauth2_proxy_cookie_secret }}
OAUTH2_PROXY_COOKIE_DOMAIN=.{{ secret_domain }}
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_UPSTREAMS=static://200
OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:4180
OAUTH2_PROXY_REDIRECT_URL=https://oauth2.{{ secret_domain }}/oauth2/callback
OAUTH2_PROXY_REVERSE_PROXY=true
OAUTH2_PROXY_SKIP_PROVIDER_BUTTON=true
OAUTH2_PROXY_SET_XAUTHREQUEST=true
