---

services:

  tailscale-media:
    container_name: tailscale-media
    image: tailscale/tailscale:v1.96.5
    hostname: media
    # Host networking is required: both Plex (bare-metal systemd service on :32400)
    # and Jellyfin (network_mode: host container on :8096) are only reachable via
    # the host network stack, not through any Docker bridge network.
    network_mode: host
    cap_add:
      - NET_ADMIN
      - NET_RAW
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - {{ docker_appdata_path }}/tailscale-media:/var/lib/tailscale
    environment:
      TS_HOSTNAME: media
      TS_AUTHKEY: "{{ secret_tailscale_auth_key_media }}"
      TS_STATE_DIR: /var/lib/tailscale
      # tailscale serve config: proxy Plex (:32400) and Jellyfin (:8096) over HTTPS
      # within the tailnet only (no funnel/public exposure).
      # Port 443 serves Jellyfin; port 32400 serves Plex at its native port.
      TS_SERVE_CONFIG: /var/lib/tailscale/serve-config.json
      # Optional: advertise a tag for ACL targeting. Requires tag:media to exist
      # in your tailnet ACL policy AND the auth key must be pre-authorized for
      # this tag. Remove this line if you don't use tagged ACLs.
      # TS_EXTRA_ARGS: "--advertise-tags=tag:media"
    restart: unless-stopped
