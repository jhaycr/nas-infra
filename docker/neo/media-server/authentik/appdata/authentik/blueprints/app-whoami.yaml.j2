version: 1
metadata:
  name: App - Whoami

entries:
  - model: authentik_providers_proxy.proxyprovider
    id: whoami-provider
    state: present
    identifiers:
      name: whoami
    attrs:
      name: whoami
      external_host: "https://whoami.{{ secret_domain }}"
      mode: forward_single
      intercept_header_auth: true
      access_token_validity: "hours=24"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]

  - model: authentik_core.application
    id: whoami-app
    state: present
    identifiers:
      slug: whoami
    attrs:
      name: whoami
      slug: whoami
      provider: !KeyOf whoami-provider
      policy_engine_mode: any

  - model: authentik_policies_expression.expressionpolicy
    id: whoami-group-policy
    state: present
    identifiers:
      name: whoami group access
    attrs:
      name: whoami group access
      expression: "return ak_is_group_member(request.user, name=\"authentik Admins\")"

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf whoami-app
      policy: !KeyOf whoami-group-policy
      order: 0
    attrs:
      enabled: true
      order: 0
      timeout: 30
