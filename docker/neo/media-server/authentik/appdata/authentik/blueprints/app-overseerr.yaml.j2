version: 1
metadata:
  name: App - Overseerr

entries:
  - model: authentik_providers_proxy.proxyprovider
    id: overseerr-provider
    state: present
    identifiers:
      name: overseerr
    attrs:
      name: overseerr
      external_host: "https://requests.{{ secret_domain }}"
      mode: forward_single
      intercept_header_auth: true
      access_token_validity: "hours=24"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]

  - model: authentik_core.application
    id: overseerr-app
    state: present
    identifiers:
      slug: overseerr
    attrs:
      name: overseerr
      slug: overseerr
      provider: !KeyOf overseerr-provider
      policy_engine_mode: any

  - model: authentik_policies_expression.expressionpolicy
    id: overseerr-group-policy
    state: present
    identifiers:
      name: overseerr group access
    attrs:
      name: overseerr group access
      expression: "return ak_is_group_member(request.user, name=\"overseerr-users\")"

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf overseerr-app
      policy: !KeyOf overseerr-group-policy
      order: 0
    attrs:
      enabled: true
      order: 0
      timeout: 30
