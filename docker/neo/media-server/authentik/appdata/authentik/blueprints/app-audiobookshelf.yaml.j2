version: 1
metadata:
  name: App - Audiobookshelf OIDC

entries:
  - model: authentik_providers_oauth2.oauth2provider
    id: audiobookshelf-provider
    state: present
    identifiers:
      name: audiobookshelf
    attrs:
      name: audiobookshelf
      client_type: confidential
      client_id: {{ secret_audiobookshelf_oidc_client_id }}
      client_secret: {{ secret_audiobookshelf_oidc_client_secret }}
      redirect_uris:
        - url: "https://audiobookshelf.{{ secret_domain }}/auth/openid/callback"
          matching_mode: strict
        - url: "https://audiobookshelf.{{ secret_domain }}/auth/openid/mobile-redirect"
          matching_mode: strict
        - url: "https://audiobooks.{{ secret_domain }}/auth/openid/callback"
          matching_mode: strict
        - url: "https://audiobooks.{{ secret_domain }}/auth/openid/mobile-redirect"
          matching_mode: strict
        - url: "https://podcasts.{{ secret_domain }}/auth/openid/callback"
          matching_mode: strict
        - url: "https://podcasts.{{ secret_domain }}/auth/openid/mobile-redirect"
          matching_mode: strict
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]

  - model: authentik_core.application
    id: audiobookshelf-app
    state: present
    identifiers:
      slug: audiobookshelf
    attrs:
      name: Audiobookshelf
      slug: audiobookshelf
      provider: !KeyOf audiobookshelf-provider
      policy_engine_mode: any

  - model: authentik_policies_expression.expressionpolicy
    id: audiobookshelf-policy
    state: present
    identifiers:
      name: audiobookshelf authenticated users
    attrs:
      name: audiobookshelf authenticated users
      expression: "return request.user.is_active"

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf audiobookshelf-app
      policy: !KeyOf audiobookshelf-policy
      order: 0
    attrs:
      enabled: true
      order: 0
      timeout: 30
