version: 1
metadata:
  name: App - Jellyfin OIDC

entries:
  - model: authentik_providers_oauth2.oauth2provider
    id: jellyfin-provider
    state: present
    identifiers:
      name: jellyfin
    attrs:
      name: jellyfin
      client_type: confidential
      client_id: {{ secret_jellyfin_oidc_client_id }}
      client_secret: {{ secret_jellyfin_oidc_client_secret }}
      redirect_uris:
        - url: "https://jellyfin.lab.{{ secret_domain }}/sso/OID/redirect/authentik"
          matching_mode: strict
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]

  - model: authentik_core.application
    id: jellyfin-app
    state: present
    identifiers:
      slug: jellyfin
    attrs:
      name: Jellyfin
      slug: jellyfin
      provider: !KeyOf jellyfin-provider
      policy_engine_mode: any

  - model: authentik_policies_expression.expressionpolicy
    id: jellyfin-group-policy
    state: present
    identifiers:
      name: jellyfin group access
    attrs:
      name: jellyfin group access
      expression: "return ak_is_group_member(request.user, name=\"Apps - Internal/Personal\")"

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf jellyfin-app
      policy: !KeyOf jellyfin-group-policy
      order: 0
    attrs:
      enabled: true
      order: 0
      timeout: 30
