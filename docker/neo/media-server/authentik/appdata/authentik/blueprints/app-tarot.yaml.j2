version: 1
metadata:
  name: App - Tarot

entries:
  - model: authentik_providers_proxy.proxyprovider
    id: tarot-provider
    state: present
    identifiers:
      name: tarot
    attrs:
      name: tarot
      external_host: "https://tarot.{{ secret_domain }}"
      mode: forward_single
      intercept_header_auth: true
      access_token_validity: "hours=24"
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]

  - model: authentik_core.application
    id: tarot-app
    state: present
    identifiers:
      slug: tarot
    attrs:
      name: Tarotarium
      slug: tarot
      provider: !KeyOf tarot-provider
      policy_engine_mode: any

  - model: authentik_policies_expression.expressionpolicy
    id: tarot-group-policy
    state: present
    identifiers:
      name: tarot group access
    attrs:
      name: tarot group access
      expression: "return ak_is_group_member(request.user, name=\"Apps - Internal/Family\") or ak_is_group_member(request.user, name=\"authentik Admins\")"

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf tarot-app
      policy: !KeyOf tarot-group-policy
      order: 0
    attrs:
      enabled: true
      order: 0
      timeout: 30
