version: 1
metadata:
  name: App - RomM OIDC

entries:
  - model: authentik_providers_oauth2.oauth2provider
    id: romm-provider
    state: present
    identifiers:
      name: romm
    attrs:
      name: romm
      client_type: confidential
      client_id: {{ secret_romm_oidc_client_id }}
      client_secret: {{ secret_romm_oidc_client_secret }}
      redirect_uris:
        - url: "https://romm.{{ secret_domain }}/api/oauth/openid"
          matching_mode: strict
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]

  - model: authentik_core.application
    id: romm-app
    state: present
    identifiers:
      slug: romm
    attrs:
      name: RomM
      slug: romm
      provider: !KeyOf romm-provider
      policy_engine_mode: any

  - model: authentik_policies_expression.expressionpolicy
    id: romm-policy
    state: present
    identifiers:
      name: romm authenticated users
    attrs:
      name: romm authenticated users
      expression: "return request.user.is_active"

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf romm-app
      policy: !KeyOf romm-policy
      order: 0
    attrs:
      enabled: true
      order: 0
      timeout: 30
