version: 1
metadata:
  name: App - Immich OIDC

entries:
  - model: authentik_providers_oauth2.oauth2provider
    id: immich-provider
    state: present
    identifiers:
      name: immich
    attrs:
      name: immich
      client_type: confidential
      client_id: {{ secret_immich_oidc_client_id }}
      client_secret: {{ secret_immich_oidc_client_secret }}
      redirect_uris:
        - url: "https://photos.{{ secret_domain }}/auth/login"
          matching_mode: strict
        - url: "https://photos.{{ secret_domain }}/api/oauth/mobile-redirect"
          matching_mode: strict
        - url: "http://192.168.1.3:2283/auth/login"
          matching_mode: strict
        - url: "app.immich:///oauth-callback"
          matching_mode: strict
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
      signing_key: !Find [authentik_crypto.certificatekeypair, [name, "authentik Self-signed Certificate"]]
      property_mappings:
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, openid]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, email]]
        - !Find [authentik_providers_oauth2.scopemapping, [scope_name, profile]]

  - model: authentik_core.application
    id: immich-app
    state: present
    identifiers:
      slug: immich
    attrs:
      name: Immich
      slug: immich
      provider: !KeyOf immich-provider
      policy_engine_mode: any

  - model: authentik_policies_expression.expressionpolicy
    id: immich-group-policy
    state: present
    identifiers:
      name: immich group access
    attrs:
      name: immich group access
      expression: "return ak_is_group_member(request.user, name=\"Apps - Internal/Family\")"

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf immich-app
      policy: !KeyOf immich-group-policy
      order: 0
    attrs:
      enabled: true
      order: 0
      timeout: 30
