networks:
  app_gramps:
    name: app_gramps
    driver: bridge

services:
  grampsweb: &grampsweb
    image: ghcr.io/gramps-project/grampsweb:latest
    container_name: gramps
    restart: always
    labels:
      - sablier.enable=true
      - sablier.group=grampsweb
    networks:
      - bridge_proxy_external
      - app_gramps
    ports:
      - "5002:5000"  # host:docker
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:5000/"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
    environment:
      GRAMPSWEB_TREE: "Gramps Web"  # will create a new tree if not exists
      GRAMPSWEB_CELERY_CONFIG__broker_url: "redis://grampsweb_redis:6379/0"
      GRAMPSWEB_CELERY_CONFIG__result_backend: "redis://grampsweb_redis:6379/0"
      GRAMPSWEB_RATELIMIT_STORAGE_URI: redis://grampsweb_redis:6379/1
      # OIDC via Zitadel — all vars require GRAMPSWEB_ prefix
      # Redirect URI to register in Zitadel: https://gramps.{{ secret_domain }}/api/oidc/callback/*
      GRAMPSWEB_OIDC_ENABLED: True
      GRAMPSWEB_OIDC_ISSUER: "https://auth.{{ secret_domain }}/application/o/gramps/"
      GRAMPSWEB_OIDC_CLIENT_ID: "{{ secret_gramps_oidc_client_id }}"
      GRAMPSWEB_OIDC_CLIENT_SECRET: "{{ secret_gramps_oidc_client_secret }}"
      GRAMPSWEB_OIDC_NAME: "Zitadel"
      GRAMPSWEB_OIDC_SCOPES: "openid email profile"
      GRAMPSWEB_OIDC_AUTO_REDIRECT: True
      GRAMPSWEB_OIDC_DISABLE_LOCAL_AUTH: True
      GRAMPSWEB_GUNICORN_NUM_WORKERS: 2
      GDK_BACKEND: offscreen

    depends_on:
      - grampsweb_redis
    volumes:
      - gramps_users:/app/users  # persist user database
      - gramps_index:/app/indexdir  # persist search index
      - gramps_thumb_cache:/app/thumbnail_cache  # persist thumbnails
      - gramps_cache:/app/cache  # persist export and report caches
      - gramps_secret:/app/secret  # persist flask secret
      - gramps_db:/root/.gramps/grampsdb  # persist Gramps database
      - gramps_media:/app/media  # persist media files
      - gramps_tmp:/tmp

  grampsweb_celery:
    <<: *grampsweb  # YAML merge key copying the entire grampsweb service config
    ports: []
    container_name: grampsweb_celery
    networks:
      - app_gramps
    labels:
      - sablier.enable=true
      - sablier.group=grampsweb
    healthcheck:
      disable: true
    depends_on:
      - grampsweb
      - grampsweb_redis
    command: celery -A gramps_webapi.celery worker --loglevel=INFO --concurrency=2

  grampsweb_redis:
    image: docker.io/library/redis:8.6.1-alpine
    container_name: grampsweb_redis
    networks:
      - app_gramps
    labels:
      - sablier.enable=true
      - sablier.group=grampsweb
    restart: always

volumes:
  gramps_users:
  gramps_index:
  gramps_thumb_cache:
  gramps_cache:
  gramps_secret:
  gramps_db:
  gramps_media:
  gramps_tmp:
