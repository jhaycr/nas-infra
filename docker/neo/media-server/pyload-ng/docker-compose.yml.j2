---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:4280e6de9727dec17eca38da03e66d5066f2e0b699edad516477858333c2998a
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped