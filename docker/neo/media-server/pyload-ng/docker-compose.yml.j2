---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:e56fc95db70171facd6a61c0e55075a9b75cf99896b111eebc48f3df4b72b47d
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped