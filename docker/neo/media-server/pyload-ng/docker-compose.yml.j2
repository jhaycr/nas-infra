---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:10b0ea37f56fd183386d74f50642acf09def18edafaa5794676d86fe5b61f497
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped