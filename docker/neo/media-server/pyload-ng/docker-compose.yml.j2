---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:56f1c750f20dd78a5b1fe2ae13e3bd262677d8ec78b1c89fd6918b93344090eb
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped