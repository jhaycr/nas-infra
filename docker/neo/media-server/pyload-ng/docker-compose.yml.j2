---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:00c2e4c357e78d7aa3fdda420501cd3cd8e30b8ed4ddd2fc556df6c104a38305
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped