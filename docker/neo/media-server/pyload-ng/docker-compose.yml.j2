---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:2d444f1f430cba5938731fb0ef8bb5e5638d449d44673917edb33625ba0e54a2
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped