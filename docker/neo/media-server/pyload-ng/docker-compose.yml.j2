---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:5051a7c79a90f9827f0dae488ae96700de79a5137b90e35df2d2eae8ead99933
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped