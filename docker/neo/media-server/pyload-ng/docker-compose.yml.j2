---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:063f4e02704233e3caa22b53a3dcf4adbe4435c43ba0bbbc1a80dabf617f99c6
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped