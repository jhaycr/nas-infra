---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:e83b18dd1d3ebb366e923470a1ac1cd6378ab0a5ac79d5b2cd2ef20815bb1fdd
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped