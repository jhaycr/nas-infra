---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:07bfb4ed6a3b853110411ba7b14aad0324c4668706dace1df680011deeea1af5
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped