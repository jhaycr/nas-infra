---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:f7d77708d1c5b302340abe8118dcb6d18915d6039b69bad7cfcb9676c4059c45
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped