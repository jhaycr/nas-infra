---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:a03f97e81a45a1f378bf05eaf2c4c874dc130660a397ff943285cdcc39fd4f19
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped