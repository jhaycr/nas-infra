---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:2ce3ef60cc1bedeaa7590e2810de95bc76dc495d639f5cfa6e20352796afdd58
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped