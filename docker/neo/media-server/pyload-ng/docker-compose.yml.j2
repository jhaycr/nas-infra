---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:a7f125bec3ed8b79d7048949e78dd3b85922ababc8d46585a98b555938777add
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped