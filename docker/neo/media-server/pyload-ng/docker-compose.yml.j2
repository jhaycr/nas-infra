---
services:

 pyload-ng:
  image: lscr.io/linuxserver/pyload-ng:latest@sha256:cf0e11fbd36800a973ffede39bf9bad6e485c94cfade389229f3edf429109b94
  container_name: pyload-ng
  volumes:
    - {{ docker_appdata_path }}/pyload-ng:/config
    - {{ nas_download_path }}/pyload:/downloads
  ports:
    - 8000:8000
    - 9666:9666 #optional
  restart: unless-stopped