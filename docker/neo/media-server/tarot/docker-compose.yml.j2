---
services:

  tarot:
    container_name: tarot
    image: ghcr.io/jhaycr/tarot:{{ tarot_image_tag }}
    networks:
      - bridge_proxy_external
    ports:
      - "8013:8000"
    volumes:
      - {{ docker_appdata_path }}/tarot:/data
    environment:
      TAROT_ADMIN_USERS: "{{ tarot_admin_users }}"
    # Multi-user: front with authentik proxy provider; identity comes from the
    # X-authentik-username header. Direct LAN access maps to user "local".
    #
    # AI interpretation: preferred path is the in-app Settings page as an admin
    # (OpenRouter/OpenAI/Anthropic/Ollama base URL + model; the API key is
    # encrypted at rest in /data). Env alternative: set TAROT_LLM_BASE_URL
    # (e.g. https://openrouter.ai/api/v1), TAROT_LLM_MODEL (e.g.
    # minimax/minimax-m2) and TAROT_LLM_API_KEY from a secret_* vault var.
    # When exposing via authentik, also set TAROT_ADMIN_USERS to the usernames
    # allowed to edit the AI connection.
